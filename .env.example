# Copy this file to .env and fill in real values. Never commit .env itself.

# NordVPN dashboard → Manual setup → "Service credentials" tab.
# This is NOT your NordVPN account login/password.
NORDVPN_OPENVPN_USER=
NORDVPN_OPENVPN_PASSWORD=

# Which NordVPN country pool gluetun should connect through.
VPN_SERVER_COUNTRIES=Germany

# Key clients must pass as ?key=... to use this MCP server. Generate a random one, e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(18))"
MCP_API_KEY=

# Only needed if you're keeping the Traefik labels in docker-compose.yml.
MCP_DOMAIN=mcp.example.com
TRAEFIK_CERT_RESOLVER=letsencrypt
RATE_LIMIT_PER_MIN=1000
RATE_LIMIT_BURST=200
